{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "useDefineForClassFields": true,
        "jsx": "react-jsx",
        "types": ["vite/client", "vitest/globals", "node"],
        "paths": {
            "@/*": ["./*"]
        }
    },
    "include": [
        "src",
        "components",
        "hooks",
        "lib",
        "services",
        "store",
        "types",
        "vite.config.ts",
        "vitest.setup.ts"
    ]
}

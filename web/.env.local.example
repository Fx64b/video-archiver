# Optional overrides — normally NOT needed.
#
# By default the frontend uses same-origin /api URLs: the Vite dev server
# (pnpm dev, ./run.sh dev) and the production nginx image both proxy /api to
# the backend. Set these only to point a build directly at a backend on a
# different origin.
#VITE_SERVER_URL=http://localhost:8080
#VITE_SERVER_URL_WS=ws://localhost:8080

# Where the Vite dev-server proxy forwards /api (default: http://localhost:8080).
#VITE_PROXY_TARGET=http://localhost:8080
